# Frontend Configuration
FRONTEND_PORT=8080
FRONTEND_CONTAINER_NAME=sar_frontend

# Backend Configuration
BACKEND_PORT=8000
BACKEND_CONTAINER_NAME=sar_backend
BACKEND_HOST=0.0.0.0

# PostgreSQL Configuration
POSTGRES_PORT=5432
POSTGRES_CONTAINER_NAME=sar_postgres
POSTGRES_USER=your_postgres_user
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=sar_db
DATABASE_URL=postgresql://your_postgres_user:your_secure_password@postgres:5432/sar_db

# Docker Build Arguments
PYTHON_VERSION=3.12
NGINX_IMAGE=nginx:alpine

# Application Environment Variables
APP_PORT=8000
APP_HOST=0.0.0.0
APP_RELOAD=true
PYTHONUNBUFFERED=1
PYTHONDONTWRITEBYTECODE=1
