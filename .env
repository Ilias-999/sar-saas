#  Frontend Configuration
FRONTEND_PORT=8080
FRONTEND_CONTAINER_NAME=sar_frontend

# Backend Configuration
BACKEND_PORT=8000
BACKEND_CONTAINER_NAME=sar_backend
BACKEND_HOST=0.0.0.0

# Docker Build Arguments
